{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "typeRoots": ["../node_modules/@types", "./node_modules/@types"]
  },
  "include": ["**/*.ts", "types.d.ts"]
}

