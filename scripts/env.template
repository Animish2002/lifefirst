# Cloudflare R2 Configuration
# Copy this file to .env in the project root and fill in your values
# Get these from your Cloudflare R2 dashboard

# Your Cloudflare Account ID
R2_ACCOUNT_ID=your_account_id_here

# R2 Access Key ID (create in R2 dashboard > Manage R2 API Tokens)
R2_ACCESS_KEY_ID=your_access_key_id_here

# R2 Secret Access Key (create in R2 dashboard > Manage R2 API Tokens)
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# R2 Bucket Name
R2_BUCKET_NAME=your_bucket_name_here

# R2 Endpoint (optional, defaults to https://{ACCOUNT_ID}.r2.cloudflarestorage.com)
# R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# Optional: Video prefix/folder in R2 (e.g., "videos/" to only process videos in that folder)
# Leave empty to process all MP4 files in the bucket
R2_VIDEO_PREFIX=

# Optional: HLS output prefix/folder (default: "hls")
# HLS files will be stored in: {R2_HLS_PREFIX}/{original_path}/{video_name}/
R2_HLS_PREFIX=hls

# HLS Segment Duration in seconds (default: 10)
# Shorter segments = faster start but more files
HLS_SEGMENT_DURATION=10

# Delete original MP4 after conversion (default: false)
# Set to "true" to delete original MP4 files after successful HLS conversion
DELETE_ORIGINAL_MP4=false

